{
  "name": "seraph-field-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "content:build": "node ./scripts/build-content.mjs",
    "dev": "npm run content:build && vite --port=3000 --host=0.0.0.0",
    "build": "npm run content:build && vite build",
    "preview": "vite preview",
    "clean": "if exist dist rmdir /s /q dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "katex": "^0.16.40",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.14.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
